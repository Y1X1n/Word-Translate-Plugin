&lt;Window x:Class="WordTranslationAddin.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="翻译插件设置" 
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F2F1">
    
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E1E1E1"/>
        <SolidColorBrush x:Key="TextPrimaryColor" Color="#323130"/>
        <SolidColorBrush x:Key="TextSecondaryColor" Color="#605E5C"/>
        
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="Margin" Value="0,16,0,12"/>
        </Style>
        
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F2F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource BackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid Height="56">
                <TextBlock Text="翻译插件设置" FontSize="20" FontWeight="SemiBold" 
                           Foreground="{StaticResource TextPrimaryColor}"
                           VerticalAlignment="Center" Margin="24,0"/>
            </Grid>
        </Border>
        
        <!-- 内容区 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <!-- 翻译引擎设置 -->
                <TextBlock Text="翻译引擎" Style="{StaticResource SectionHeaderStyle}"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="首选翻译引擎" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="EngineComboBox" Style="{StaticResource ComboBoxStyle}">
                            <ComboBoxItem Content="谷歌翻译" Tag="Google"/>
                            <ComboBoxItem Content="百度翻译" Tag="Baidu"/>
                            <ComboBoxItem Content="DeepL" Tag="DeepL"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="目标语言" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="LanguageComboBox" Style="{StaticResource ComboBoxStyle}">
                            <ComboBoxItem Content="中文（简体）" Tag="zh"/>
                            <ComboBoxItem Content="中文（繁体）" Tag="zh-TW"/>
                            <ComboBoxItem Content="英语" Tag="en"/>
                            <ComboBoxItem Content="日语" Tag="ja"/>
                            <ComboBoxItem Content="韩语" Tag="ko"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
                
                <!-- API 设置 -->
                <TextBlock Text="API 配置" Style="{StaticResource SectionHeaderStyle}"/>
                
                <StackPanel>
                    <TextBlock Text="谷歌翻译 API Key" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="GoogleApiKeyBox" Style="{StaticResource TextBoxStyle}"/>
                    
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="百度翻译 App ID" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="BaiduAppIdBox" Style="{StaticResource TextBoxStyle}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="百度翻译密钥" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="BaiduSecretKeyBox" Style="{StaticResource TextBoxStyle}"/>
                        </StackPanel>
                    </Grid>
                    
                    <TextBlock Text="DeepL API Key" Style="{StaticResource LabelStyle}" Margin="0,12,0,0"/>
                    <TextBox x:Name="DeepLApiKeyBox" Style="{StaticResource TextBoxStyle}"/>
                </StackPanel>
                
                <!-- 功能设置 -->
                <TextBlock Text="功能设置" Style="{StaticResource SectionHeaderStyle}"/>
                
                <StackPanel>
                    <CheckBox x:Name="OfflineModeCheckBox" Content="启用离线翻译模式" Style="{StaticResource CheckBoxStyle}"/>
                    <CheckBox x:Name="AutoCopyCheckBox" Content="自动复制翻译结果" Style="{StaticResource CheckBoxStyle}"/>
                    <CheckBox x:Name="ShowPhoneticCheckBox" Content="显示音标" Style="{StaticResource CheckBoxStyle}"/>
                    <CheckBox x:Name="ShowExamplesCheckBox" Content="显示例句" Style="{StaticResource CheckBoxStyle}"/>
                    <CheckBox x:Name="EnableAnimationCheckBox" Content="启用动画效果" Style="{StaticResource CheckBoxStyle}"/>
                </StackPanel>
                
                <!-- 弹窗设置 -->
                <TextBlock Text="弹窗设置" Style="{StaticResource SectionHeaderStyle}"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="弹窗位置" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="PopupPositionComboBox" Style="{StaticResource ComboBoxStyle}">
                            <ComboBoxItem Content="自动" Tag="Auto"/>
                            <ComboBoxItem Content="光标位置" Tag="Cursor"/>
                            <ComboBoxItem Content="屏幕中心" Tag="Center"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="主题" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="ThemeComboBox" Style="{StaticResource ComboBoxStyle}">
                            <ComboBoxItem Content="跟随系统" Tag="System"/>
                            <ComboBoxItem Content="浅色" Tag="Light"/>
                            <ComboBoxItem Content="深色" Tag="Dark"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
        
        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="{StaticResource BackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,16">
                <Button x:Name="CancelButton" Content="取消" Style="{StaticResource SecondaryButtonStyle}" 
                        Click="CancelButton_Click" Margin="0,0,12,0"/>
                <Button x:Name="SaveButton" Content="保存" Style="{StaticResource ButtonStyle}" 
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
